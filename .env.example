# ==============================
# TanqitFlow — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ==============================

# --- PostgreSQL ---
POSTGRES_USER=tanqit
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=tanqitflow

# --- Redis ---
# No password needed for local dev; add requirepass for prod
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=tanqitminio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=tanqitflow-uploads

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_strong_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PII Encryption (Law 09-08) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# --- App ---
ENVIRONMENT=development
# Options: development | staging | production

# --- SMTP (for user welcome emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@tanqitflow.ma

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000
